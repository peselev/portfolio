---
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Konstantin Peselev — Senior Product Manager"
  description="Senior PM with 10+ years building B2B SaaS. Most recently leading Growth, Data Governance, and AI roadmaps at Totango."
>
  <!-- Hero / intro -->
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16">
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-gray-900 tracking-tight leading-[1.1] mb-10 max-w-2xl">
      Senior Product Manager · 10+ years in SaaS
    </h1>

    <div class="prose-intro space-y-5 text-lg text-gray-700 leading-relaxed max-w-2xl">
      <p>
        Code-literate enough to debate architecture with engineers.
        Business-literate enough to defend the roadmap to a CEO.
        The interesting work happens in the gap between — and that's where I've spent the last decade.
      </p>
      <p>
        Based in Philadelphia, with regular time in NYC.
      </p>
      <p>
        Most recently at Totango, leading Growth, Data Governance, and AI for a $40M ARR platform serving SAP, GitHub, and Dynatrace.
        Earlier: an MBA from NYU Stern, two startups (one exit, another grew past $1M ARR and closed its next VC round), and an EE degree that still pays dividends in technical conversations.
      </p>
    </div>

    <div class="mt-8 max-w-2xl text-lg text-gray-700 leading-relaxed space-y-3">
      <p><strong class="text-gray-900">My style.</strong> Three principles that guide how I work:</p>
      <ul class="space-y-3 pl-0 list-none">
        <li class="flex gap-3">
          <span class="text-accent-700 font-semibold shrink-0">·</span>
          <span>Revenue is the scoreboard: if customers don't pay, the work wasn't worth it.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-accent-700 font-semibold shrink-0">·</span>
          <span>Growth has to be sustainable: a quarter of steeper numbers isn't worth a year of tech debt.</span>
        </li>
        <li class="flex gap-3">
          <span class="text-accent-700 font-semibold shrink-0">·</span>
          <span>People make decisions and own the consequences. AI implements.</span>
        </li>
      </ul>
    </div>

    <div class="mt-8 max-w-2xl border-l-2 border-accent-700 pl-5">
      <p class="text-base text-gray-700 italic leading-relaxed">
        Decide more than you investigate, investigate more than you delegate, and delegate as much as you can.
      </p>
      <p class="text-sm text-gray-500 mt-2">My mantra on AI agents and LLM work.</p>
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="#work"
        class="bg-accent-700 hover:bg-accent-900 text-white font-medium px-6 py-3 rounded-lg transition-colors"
      >
        See selected work
      </a>
      <a
        href="mailto:peselevk@gmail.com"
        class="border border-gray-300 hover:border-gray-900 text-gray-900 font-medium px-6 py-3 rounded-lg transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>

  <!-- Work gallery -->
  <section id="work" class="max-w-5xl mx-auto px-6 py-20">
    <p class="text-xs uppercase tracking-widest font-semibold text-accent-700 mb-3">Selected work</p>
    <h2 class="font-display text-3xl md:text-4xl font-semibold text-gray-900 mb-12 max-w-2xl">
      Case studies from the last few years.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard
          href={`/work/${project.id}`}
          title={project.data.title}
          summary={project.data.summary}
          company={project.data.company}
          tags={project.data.tags}
        />
      ))}
    </div>
  </section>
</Base>
