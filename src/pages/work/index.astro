---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Work — Konstantin Peselev"
  description="Complete list of product management case studies and projects."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-24">
    <p class="text-xs uppercase tracking-widest font-semibold text-accent-700 mb-3">Work</p>
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-gray-900 tracking-tight mb-6">
      Every case study, in one place.
    </h1>
    <p class="text-lg text-gray-600 mb-12 max-w-2xl">
      A complete archive of projects across Growth, Data Governance, and AI roadmaps.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard
          href={`/work/${project.id}`}
          title={project.data.title}
          summary={project.data.summary}
          role={project.data.role}
          period={project.data.period}
          tags={project.data.tags}
        />
      ))}
    </div>
  </section>
</Base>
