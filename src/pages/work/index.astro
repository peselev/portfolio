---
import Base from "../../layouts/Base.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="The work — Konstantin Peselev"
  description="Case studies of product decisions, with the problem, the calls I made, what shipped, and what I'd do differently."
>
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-24">
    <h1 class="font-display text-4xl md:text-5xl font-semibold text-gray-900 tracking-tight mb-6">
      The work
    </h1>
    <p class="text-lg text-gray-600 mb-12 max-w-2xl">
      Each case below is a story — the problem, the call I made, what shipped, what I'd do differently.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <ProjectCard
          href={`/work/${project.id}`}
          title={project.data.title}
          summary={project.data.summary}
          company={project.data.company}
          tags={project.data.tags}
        />
      ))}
    </div>
  </section>
</Base>
