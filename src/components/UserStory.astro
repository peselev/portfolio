---
export interface Props {
  label?: string;
}

const { label = "User Story" } = Astro.props;
---

<aside class="border-l-2 border-gray-300 pl-5 py-1 my-5">
  <p class="text-xs uppercase tracking-widest font-bold text-gray-900 mb-2">
    {label}
  </p>
  <div class="text-gray-800 text-sm leading-relaxed user-story-content">
    <slot />
  </div>
</aside>

<style is:global>
  .user-story-content > p {
    margin-bottom: 0.75rem;
    font-size: 0.875rem !important;
  }
  .user-story-content > p:last-child {
    margin-bottom: 0;
  }
</style>
