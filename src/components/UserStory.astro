---
// Subtle, quiet styling. Single story or multiple stories supported.
// Pass `count={2}` etc. if you want pluralized label, otherwise defaults to "USER STORY".
export interface Props {
  label?: string;
}

const { label = "User Story" } = Astro.props;
---

<aside class="border-l-2 border-gray-300 bg-gray-50 rounded-r-md px-5 py-4 my-5">
  <p class="text-xs uppercase tracking-widest font-semibold text-gray-500 mb-2">
    {label}
  </p>
  <div class="text-gray-800 text-base leading-relaxed user-story-content">
    <slot />
  </div>
</aside>

<style is:global>
  .user-story-content > p:last-child { margin-bottom: 0; }
  .user-story-content > ul {
    margin: 0;
    padding-left: 1.25rem;
    list-style-type: disc;
  }
  .user-story-content > ul > li { margin-bottom: 0.25rem; }
  .user-story-content > ul > li:last-child { margin-bottom: 0; }
</style>
