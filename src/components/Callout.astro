---
export interface Props {
  title?: string;
  variant?: "info" | "insight" | "warning";
}

const { title, variant = "info" } = Astro.props;

const variants = {
  info: "border-accent-700 bg-accent-50",
  insight: "border-amber-500 bg-amber-50",
  warning: "border-red-500 bg-red-50",
};

const labels = {
  info: "Note",
  insight: "Insight",
  warning: "Caveat",
};
---

<aside class:list={["border-l-4 p-5 my-6 rounded-r-lg", variants[variant]]}>
  {title && (
    <p class="text-xs uppercase tracking-widest font-semibold text-gray-700 mb-2">
      {title || labels[variant]}
    </p>
  )}
  <div class="text-gray-800 text-base leading-relaxed">
    <slot />
  </div>
</aside>
