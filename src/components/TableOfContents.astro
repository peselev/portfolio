---
// Sticky sidebar TOC: H2 (top level) and H3 (indented).
// Active section highlights as user scrolls.
---

<aside id="case-toc" class="hidden xl:block fixed right-8 top-32 w-56 z-30">
  <p class="text-xs uppercase tracking-widest font-semibold text-gray-500 mb-3">
    On this page
  </p>
  <nav id="case-toc-nav" class="text-sm border-l border-gray-200 pl-4">
    <!-- Links injected by script -->
  </nav>
</aside>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const article = document.querySelector(".prose-case");
    const nav = document.getElementById("case-toc-nav");
    const toc = document.getElementById("case-toc");
    if (!article || !nav || !toc) return;

    // Only top-level headings — exclude anything inside <details>
    // (collapsed content shouldn't trigger active state)
    const headings = Array.from(
      article.querySelectorAll("h2, h3")
    ).filter((h) => !h.closest("details")) as HTMLElement[];

    if (headings.length < 2) {
      toc.style.display = "none";
      return;
    }

    const slugify = (txt: string) =>
      txt
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-");

    // Build TOC links
    const links: HTMLAnchorElement[] = [];
    headings.forEach((h) => {
      if (!h.id) h.id = slugify(h.textContent || "");
      const link = document.createElement("a");
      link.href = `#${h.id}`;
      link.textContent = h.textContent;
      const isH3 = h.tagName === "H3";
      link.className = [
        "toc-link block py-1 leading-snug transition-colors",
        isH3 ? "pl-4 text-[0.8rem]" : "font-medium",
      ].join(" ");
      link.dataset.target = h.id;
      // Default (inactive) color
      link.style.color = "#6b7280"; // gray-500
      nav.appendChild(link);
      links.push(link);
    });

    // Track currently active heading by index using scroll position.
    // Approach: find the last heading whose top is above 1/3 of viewport.
    const setActive = (activeId: string | null) => {
      links.forEach((l) => {
        if (l.dataset.target === activeId) {
          l.style.color = "#4338ca"; // accent-700
        } else {
          l.style.color = "#6b7280"; // gray-500
        }
      });
    };

    const onScroll = () => {
      const threshold = window.innerHeight * 0.33;
      let activeId: string | null = headings[0].id;
      for (const h of headings) {
        const rect = h.getBoundingClientRect();
        if (rect.top <= threshold) {
          activeId = h.id;
        } else {
          break;
        }
      }
      setActive(activeId);
    };

    // Throttle scroll via rAF
    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });
    onScroll(); // initial state
  });
</script>
