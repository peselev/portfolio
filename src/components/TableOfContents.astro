---
// Sticky sidebar TOC: auto-generated client-side from H2 headings within .prose-case
// Highlights the active section as the user scrolls.
---

<aside id="case-toc" class="hidden xl:block fixed right-8 top-32 w-56 z-30">
  <p class="text-xs uppercase tracking-widest font-semibold text-gray-500 mb-3">
    On this page
  </p>
  <nav id="case-toc-nav" class="text-sm space-y-2 border-l border-gray-200 pl-4">
    <!-- Links injected by script -->
  </nav>
</aside>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const article = document.querySelector(".prose-case");
    const nav = document.getElementById("case-toc-nav");
    const toc = document.getElementById("case-toc");
    if (!article || !nav || !toc) return;

    const headings = article.querySelectorAll("h2");
    if (headings.length < 2) {
      toc.style.display = "none";
      return;
    }

    headings.forEach((h) => {
      if (!h.id) {
        const slug = (h.textContent || "")
          .toLowerCase()
          .trim()
          .replace(/[^\w\s-]/g, "")
          .replace(/\s+/g, "-");
        h.id = slug;
      }
      const link = document.createElement("a");
      link.href = `#${h.id}`;
      link.textContent = h.textContent;
      link.className =
        "block text-gray-500 hover:text-gray-900 transition-colors leading-snug toc-link";
      link.dataset.target = h.id;
      nav.appendChild(link);
    });

    // Active section highlighting via IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = (entry.target as HTMLElement).id;
          const link = nav.querySelector(`[data-target="${id}"]`);
          if (!link) return;
          if (entry.isIntersecting) {
            nav
              .querySelectorAll(".toc-link")
              .forEach((l) => l.classList.remove("text-accent-700", "font-medium"));
            link.classList.add("text-accent-700", "font-medium");
          }
        });
      },
      { rootMargin: "-20% 0px -70% 0px" }
    );
    headings.forEach((h) => observer.observe(h));
  });
</script>
