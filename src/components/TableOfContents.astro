---
// Sticky sidebar TOC: H2 (top level) and H3 (indented).
// Active section is highlighted in indigo and tracked by a moving indicator
// overlay on the left vertical line (Claude-docs style).
---

<aside id="case-toc" class="hidden xl:block fixed right-8 top-32 w-56 z-30">
  <p class="text-xs uppercase tracking-widest font-semibold text-gray-500 mb-3">
    On this page
  </p>
  <div class="case-toc-wrapper">
    <span id="case-toc-indicator" class="case-toc-indicator" aria-hidden="true"></span>
    <nav id="case-toc-nav" class="case-toc-nav text-sm">
      <!-- Links injected by script -->
    </nav>
  </div>
</aside>

<style>
  .case-toc-wrapper {
    position: relative;
  }
  /* Gray rail (the static vertical line) */
  .case-toc-nav {
    border-left: 1px solid #e5e7eb;
    padding-left: 1rem;
  }
  /* Colored indicator overlaying part of the rail */
  .case-toc-indicator {
    position: absolute;
    left: 0;
    width: 1px;
    background: #4338ca;
    height: 0;
    top: 0;
    transition: top 0.2s ease, height 0.2s ease;
    pointer-events: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const article = document.querySelector(".prose-case");
    const nav = document.getElementById("case-toc-nav");
    const toc = document.getElementById("case-toc");
    const indicator = document.getElementById("case-toc-indicator");
    if (!article || !nav || !toc || !indicator) return;

    const headings = Array.from(
      article.querySelectorAll("h2, h3")
    ).filter((h) => !h.closest("details")) as HTMLElement[];

    if (headings.length < 2) {
      toc.style.display = "none";
      return;
    }

    const slugify = (txt: string) =>
      txt
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, "")
        .replace(/\s+/g, "-");

    const links: HTMLAnchorElement[] = [];
    headings.forEach((h) => {
      if (!h.id) h.id = slugify(h.textContent || "");
      const link = document.createElement("a");
      link.href = `#${h.id}`;
      link.textContent = h.textContent;
      const isH3 = h.tagName === "H3";
      link.className = [
        "toc-link block py-1 leading-snug transition-colors",
        isH3 ? "pl-4 text-[0.8rem]" : "font-medium",
      ].join(" ");
      link.dataset.target = h.id;
      link.style.color = "#6b7280";
      nav.appendChild(link);
      links.push(link);
    });

    const setActive = (activeId: string | null) => {
      let activeLink: HTMLAnchorElement | null = null;
      links.forEach((l) => {
        if (l.dataset.target === activeId) {
          l.style.color = "#4338ca";
          activeLink = l;
        } else {
          l.style.color = "#6b7280";
        }
      });
      if (activeLink) {
        const navRect = nav.getBoundingClientRect();
        const linkRect = (activeLink as HTMLAnchorElement).getBoundingClientRect();
        const top = linkRect.top - navRect.top;
        const height = linkRect.height;
        indicator.style.top = `${top}px`;
        indicator.style.height = `${height}px`;
      } else {
        indicator.style.height = "0";
      }
    };

    const onScroll = () => {
      const threshold = window.innerHeight * 0.33;
      let activeId: string | null = headings[0].id;
      for (const h of headings) {
        const rect = h.getBoundingClientRect();
        if (rect.top <= threshold) {
          activeId = h.id;
        } else {
          break;
        }
      }
      setActive(activeId);
    };

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          onScroll();
          ticking = false;
        });
        ticking = true;
      }
    });
    window.addEventListener("resize", () => onScroll());
    onScroll();
  });
</script>
