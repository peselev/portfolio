---
export interface Metric {
  value: string;
  label: string;
  detail?: string;
  /** Optional Tailwind text-size class (e.g. "text-3xl", "text-2xl") to override the default 4xl value size. */
  valueSize?: string;
}

export interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
const count = metrics.length;
---

<div
  class="metric-grid my-10"
  style={`--metric-count: ${count};`}
>
  {metrics.map((m) => (
    <div class="border border-gray-200 rounded-xl p-6 bg-white">
      <p class:list={[
        "font-display font-semibold text-accent-700 tracking-tight",
        m.valueSize ?? "text-4xl"
      ]}>{m.value}</p>
      <p class="text-sm font-medium text-gray-900 mt-2">{m.label}</p>
      {m.detail && <p class="text-sm text-gray-600 mt-1">{m.detail}</p>}
    </div>
  ))}
</div>

<style>
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(var(--metric-count), minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (max-width: 640px) {
    .metric-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
